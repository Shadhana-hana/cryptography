while True:
    print("\n--- SUBSTITUTION CIPHERS MENU ---")
    print("1. Caesar Cipher")
    print("2. Playfair Cipher")
    print("3. Hill Cipher")
    print("4. Exit")

    choice = input("Enter choice: ")

    if choice == "4":
        break

    text = input("Enter text: ").upper()
    text = "".join(c for c in text if c.isalpha())

    mode = input("Encrypt (E) / Decrypt (D): ").upper()
    encrypt = True if mode == "E" else False

    if choice == "1":
        caesar(text, encrypt)

    elif choice == "2":
        key = input("Enter Playfair key: ").upper()
        playfair(text, key, encrypt)

    elif choice == "3":
        key = input("Enter 2×2 matrix values (a b c d): ")
        hill(text, key, encrypt)

    else:
        print("Invalid choice")




